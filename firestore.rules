rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the requester an admin?
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users: logged-in can read all; own profile to write, admin can update
    // (admin update is needed to grant/revoke Premium plan)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Premium interest (Early Bird waitlist): anyone may register interest,
    // only admin can read the list
    match /premiumInterest/{docId} {
      allow create: if request.resource.data.email is string
        && request.resource.data.email.size() > 3;
      allow read, update, delete: if isAdmin();
    }

    // Premium payment requests (manual PromptPay): user creates own request,
    // reads own; admin reads all and approves/rejects
    match /premiumRequests/{reqId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    // Cats: logged-in can read all, only owner can write
    match /cats/{catId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;

      // Health records: only cat owner
      match /healthRecords/{recordId} {
        allow read, write: if request.auth != null &&
          get(/databases/$(database)/documents/cats/$(catId)).data.ownerId == request.auth.uid;
      }
    }

    // Likes & Passes
    match /likes/{likeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.fromUserId == request.auth.uid;
    }
    match /passes/{passId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.fromUserId == request.auth.uid;
    }

    // Matches: participants only (resource == null allows checking existence before creation)
    match /matches/{matchId} {
      allow read: if request.auth != null && (resource == null || request.auth.uid in resource.data.users);
      allow create: if request.auth != null && request.auth.uid in request.resource.data.users;
    }

    // Chats: messages only — parent chat doc is never created directly.
    // Authorization is verified via the parent match document's users array.
    match /chats/{chatId} {
      // Allow authenticated users to read chat metadata (we don't write parent docs)
      allow read: if request.auth != null;

      match /messages/{msgId} {
        // Only users who are part of the match can read/write messages
        allow read: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/matches/$(chatId)).data.users;
        allow create: if request.auth != null &&
          request.resource.data.senderId == request.auth.uid &&
          request.auth.uid in get(/databases/$(database)/documents/matches/$(chatId)).data.users;
      }
    }

    // Directory: public read, admin-only write
    match /directory/{listingId} {
      allow read: if true;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';

      // Reviews: logged-in can create/read, own review to update/delete
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      }
    }

  }
}
