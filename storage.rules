rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Cat photos and documents: owner can write, any authenticated user can read
    match /cats/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024; // 10MB limit
    }

    // Article images: admin-only write, public read
    match /articles/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User avatars: owner write, authenticated read
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024;
    }

    // Payment slips (PromptPay manual): owner writes, authenticated reads
    // (admin verifies via the app)
    match /premiumSlips/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024;
    }
  }
}
